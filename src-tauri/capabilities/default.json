{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "store:default",
    "core:event:default",
    "opener:default",
    "dialog:default",
    "drag:default",
    "updater:default",
    "process:allow-restart",
    "shell:allow-open",
    "dialog:allow-ask"
  ]
}
