{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwiftShare",
  "version": "0.1.0",
  "identifier": "com.goldon.tauri-app",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
"windows": [
      {
        "title": "SwiftShare",
        "width": 900,
        "height": 650,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true,
        "decorations": true,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/RSJWY/SwiftShare/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1M0ZGNkU1OUM5Qzg5N0UKUldSK2laeWM1ZlkvOWFuSCtBTFRVL2dJeWJieVlJa2NLZmRldnZzcG5rUTJsMjdrMGRDU3lPU0YK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
